# Better Sonos Controller — configuration
# Edit this file if needed. No separate .env required.
#
# Setup:     ./local-scripts/setup.sh
# Autostart: ./local-scripts/setup.sh --autostart

SONOS_ENABLED=1
SONOS_MOBILE_BIND=0.0.0.0
SONOS_MOBILE_PORT=8766
SONOS_DISCOVERY_TIMEOUT=5

# Set fixed speaker IPs only if auto-discovery fails (comma-separated)
# SONOS_IP=192.168.1.50,192.168.1.51
SONOS_IP=
